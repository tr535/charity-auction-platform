    private readonly IUserService _userService;

        public UserController(IUserService userService)
        {
            _userService = userService;
        }

        [HttpPost("register")]
        public async Task<IActionResult> Register([FromBody] RegisterDTO rDto)
        {
            // וולידציה בסיסית של המודל (מגיע מובנה עם [ApiController])
            var result = await _userService.RegisterAsync(rDto);

            if (!result.Success)
                return BadRequest(result.Message);

            return Ok(new { message = "User registered successfully" });
        }

        [HttpPost("login")]
        public async Task<IActionResult> Login([FromBody] LoginDTO lDto)
        {
            var authResponse = await _userService.LoginAsync(lDto);

            if (authResponse == null)
                return Unauthorized(new { message = "Invalid email or password" });

            return Ok(authResponse); // מחזיר DTO שכולל Token, Role, ו-Expiration
        }

    }


