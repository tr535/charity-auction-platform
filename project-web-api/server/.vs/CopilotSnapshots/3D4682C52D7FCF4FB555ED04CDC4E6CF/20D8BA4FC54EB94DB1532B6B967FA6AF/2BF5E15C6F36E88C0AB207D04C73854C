using Microsoft.AspNetCore.Mvc;
using server.BLL;
using server.Models;
using server.Models.DTO;

namespace server.Controllers
{
    public class UserController : ControllerBase
    {

        private readonly IUserService userService;

        public UserController(IUserService userService)
        {
            this.userService = userService;
        }

        [HttpGet]
        public IEnumerable<User> Get()
        {

            return userService.Get();

        }

        // GET api/<FamilyController>/5
        [HttpGet("{id}")]
        public User Get(int id)
        {
            return userService.Get(id);
        }



        // POST api/<FamilyController>
        [HttpPost]
        public void Post([FromBody] UserDTO userD)
        {
            userService.Add(userD);

        }


        // PUT api/<FamilyController>/5
        [HttpPut("{id}")]
        public void Put(int id, [FromBody] UserDTO userD)
        {
            userService.Update(id, userD);

        }

        // DELETE api/<FamilyController>/5
        [HttpDelete("{id}")]
        public void Delete(int id)
        {
            userService.Remove(id);

        }


    }


}
