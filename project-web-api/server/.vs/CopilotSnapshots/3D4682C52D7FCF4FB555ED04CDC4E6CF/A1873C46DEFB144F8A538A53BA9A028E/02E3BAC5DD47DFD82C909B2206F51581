using AutoMapper;
using server.DAL;
using server.Models;
using server.Models.DTO;

namespace server.BLL
{
    public class UserService
    {


        private readonly IUserDal userDal;
        private readonly IMapper mapper;


        public UserService(IUserDal userDal, IMapper mapper)
        {
            this.userDal = userDal;
            this.mapper = mapper;

        }
        public void Add(UserDTO userD)
        {

            userDal.Add(userD);
        }

        public void Remove(UserDTO userD)
        {
            userDal.Remove(userD);
        }

        public User? Get(int id)
        {
            return userDal.Get(id);
        }

        public List<User> Get()
        {
            return userDal.Get();
        }

        public void Update(int id, UserDTO userD)

        {
            //Gift gift =
            return userDal.Update(id, userD);
        }
    }
}

